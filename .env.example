# ─── OBRIGATÓRIAS ────────────────────────────────────────────────────────────
ADMIN_TOKEN=seu_token_aqui

# Mercado Livre (OAuth)
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=http://localhost:8000/api/ml/callback
# ML_WEBHOOK_SECRET=        # protege /api/ml/webhook; re-registrar via /api/admin/ml/registrar-webhook após definir

# ─── BANCO DE DADOS ───────────────────────────────────────────────────────────
# Deixe em branco para usar SQLite local (apostilas.db)
# Preencha só durante a migração do Render:
# DATABASE_URL=postgresql://user:pass@host/db

# ─── CATEGORIAS ML (opcionais — já têm default no código) ────────────────────
# ML_CATEGORIA_FISICO_ID=MLB271599
# ML_CATEGORIA_DIGITAL_ID=MLB1227
# ML_CATEGORIA_ID=          # legado — sobrescreve tudo se definido

# ─── PREÇOS PADRÃO ───────────────────────────────────────────────────────────
# PRECO_FISICO=29.90
# PRECO_DIGITAL=9.90

# ─── SHOPEE (só se for usar) ─────────────────────────────────────────────────
# SHOPEE_PARTNER_ID=
# SHOPEE_PARTNER_KEY=
# SHOPEE_SHOP_ID=
# SHOPEE_REDIRECT_URI=http://localhost:8000/api/shopee/callback
# SHOPEE_CATEGORIA_ID=
# SHOPEE_LOGISTICA_ID=

# ─── YOUTUBE (OAuth — para clipes automáticos no ML Decola) ─────────────────
# GOOGLE_CLIENT_ID=         # Google Cloud Console → Credenciais → OAuth 2.0
# GOOGLE_CLIENT_SECRET=     # mesmo projeto
# YOUTUBE_REDIRECT_URI=http://localhost:8000/api/youtube/callback

# ─── GERAÇÃO DE IMAGENS AI (opcional) ────────────────────────────────────────
# DASHSCOPE_API_KEY=        # Qwen/Alibaba (capas com IA)
# ANTHROPIC_API_KEY=        # Claude
# GROQ_API_KEY=

# ─── ARMAZENAMENTO R2 (opcional — imagens na nuvem) ──────────────────────────
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ACCOUNT_ID=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# ─── SERVIDOR ────────────────────────────────────────────────────────────────
# PORT=8000

# Geracao de imagem (Together AI) - tipografia PT correta
# TOGETHER_API_KEY=
# TOGETHER_IMAGE_MODEL=ByteDance-Seed/Seedream-4.0   # default; alt: Qwen/Qwen-Image-2.0-Pro (melhor, 2.6x mais caro)
